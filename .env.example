# ===================================================================
#  Portfolio — Configuration
#  Copiez ce fichier en `.env` puis remplacez les valeurs.
#    cp .env.example .env
#
#  NB : les variables NEXT_PUBLIC_* sont injectées au BUILD.
#       Après modification, relancez `npm run dev` (ou rebuild en prod).
# ===================================================================

# -------------------------------------------------------------------
#  Base de données PostgreSQL (blog + projets)
#  - Local via Docker :  voir docker-compose.yml (docker compose up -d)
#  - Hébergé          :  Neon, Supabase, Railway, Prisma Postgres...
# -------------------------------------------------------------------
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio?schema=public"

# -------------------------------------------------------------------
#  Identité
# -------------------------------------------------------------------
NEXT_PUBLIC_FIRST_NAME="Louka"
NEXT_PUBLIC_LAST_NAME="Lemonnier"
NEXT_PUBLIC_ROLE="Développeur Full-Stack"
NEXT_PUBLIC_TAGLINE="Je conçois et déploie des applications web modernes, du front à l'infra."
NEXT_PUBLIC_LOCATION="Nantes, France"

# Bio affichée dans la section « À propos » (peut contenir plusieurs phrases).
NEXT_PUBLIC_BIO="Étudiant en M1 DevOps, passionné par le développement web et l'automatisation. J'aime construire des produits soignés, des pipelines CI/CD fiables et apprendre de nouvelles technologies."

# Photo de profil : URL absolue (https://...) ou chemin local dans /public (ex : /avatar.jpg)
NEXT_PUBLIC_AVATAR_URL=""

# CV téléchargeable : URL absolue ou chemin local dans /public (ex : /cv.pdf). Laissez vide pour masquer le bouton.
NEXT_PUBLIC_RESUME_URL=""

# -------------------------------------------------------------------
#  Contact
# -------------------------------------------------------------------
NEXT_PUBLIC_EMAIL="lk.lemonnier@gmail.com"
NEXT_PUBLIC_PHONE="+33 7 69 19 06 82"

# -------------------------------------------------------------------
#  Réseaux sociaux (laissez vide pour masquer le lien)
# -------------------------------------------------------------------
