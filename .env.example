# -------------------------------------------------------------------
#  Site (métadonnées SEO / Open Graph)
# -------------------------------------------------------------------
# URL publique du site (sans slash final), utilisée pour le SEO et les liens absolus.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
